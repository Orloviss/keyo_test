{
  "extends": ["stylelint-config-standard-scss"],
  "ignoreFiles": [
    "**/node_modules/**",
    "wp-admin/**",
    "wp-includes/**",
    "wp-content/plugins/*",
    "!wp-content/plugins/keyo-workspace/**",
    "wp-content/themes/keyo_test-child/style.css"
  ],
  "rules": {
    "scss/at-rule-no-unknown": true,
    "no-empty-source": null
  }
}
