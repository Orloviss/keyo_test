<?xml version="1.0"?>
<ruleset name="KeyoFullProjectRuleset">
   
    <file>./wp-content/plugins/keyo-workspace</file>
    <file>./wp-content/themes/keyo_test</file>
    <file>./wp-content/themes/keyo_test-child</file>

    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/js/*</exclude-pattern>

    <rule ref="PSR12"/>
    
    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
        <exclude-pattern>*.php</exclude-pattern> 
    </rule>

    <arg name="extensions" value="php"/>
    <arg value="sp"/>
</ruleset>