{
  "name": "keyo-test",
  "version": "1.0.0",
  "description": "Keyo test package config",
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "lint:scss": "stylelint \"wp-content/themes/**/*.scss\" \"wp-content/plugins/keyo-workspace/**/*.scss\"",
    "lint:scss:fix": "stylelint \"wp-content/themes/**/*.scss\" \"wp-content/plugins/keyo-workspace/**/*.scss\" --fix",
    "lint:js": "eslint \"wp-content/themes/**/*.js\"",
    "lint:js:fix": "eslint \"wp-content/themes/**/*.js\" --fix",
    "lint:php": "phpcs",
    "lint:php:fix": "phpcbf"
  },
  "devDependencies": {
    "css-loader": "^7.0.0",
    "eslint": "^9.0.0",
    "mini-css-extract-plugin": "^2.9.0",
    "sass": "^1.70.0",
    "sass-loader": "^14.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-scss": "^6.0.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
